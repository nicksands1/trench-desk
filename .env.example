# ── Trench Desk environment ───────────────────────────────────────────────
# Copy to `.env.local` (Next) and/or `.env` (worker). NEVER commit real values.
# Every var is read via process.env. Missing keys degrade gracefully (the app
# still builds and renders); features that need them log under NEEDS NICK.

# ── Required for live data ────────────────────────────────────────────────
# Helius RPC + Enhanced Transactions API key (free tier is fine).
HELIUS_API_KEY=
# Postgres connection string (Neon / Supabase / Railway). Absent => DB no-ops.
DATABASE_URL=

# ── Recommended: Telegram alerts (send-only; no-op if absent) ──────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional, defaulted (scout throttle) ──────────────────────────────────
SCOUT_CONCURRENCY=3
SCOUT_MIN_INTERVAL_MS=1500
SCOUT_DEDUPE_SEC=1800

# ── Optional, defaulted (screener) ────────────────────────────────────────
# Comma-separated subset of A,B,C,D,E,F that are active.
SCREENER_PRESETS=A,B,C,D,E,F

# ── Optional, defaulted (holder velocity — module 6) ──────────────────────
HV_POLL_INTERVAL_SEC=300

# ── Optional, defaulted (smart money — module 7) ──────────────────────────
SMART_MONEY_MIN_WALLETS=2
SMART_MONEY_WINDOW_MIN=45

# ── Optional, defaulted (scoreboard outcome tracker — module 8) ───────────
OUTCOME_POLL_INTERVAL_SEC=600
OUTCOME_MAX_WINDOW_HRS=72
RUG_LIQUIDITY_FLOOR_USD=1000

# ── Optional, paid (NEVER required — features degrade without them) ────────
BIRDEYE_API_KEY=
# rugcheck reads are keyless; a JWT only raises rate limits.
RUGCHECK_JWT=

# ── Optional: Vercel Cron per-tick endpoints (the no-24/7-host option) ─────
# If set, /api/cron/* requires `Authorization: Bearer <CRON_SECRET>` (Vercel
# Cron sends this automatically). Leave empty to run the always-on worker.
CRON_SECRET=

# ── Optional: alert links ─────────────────────────────────────────────────
# Public URL of your deployed dashboard, e.g. https://trench-desk.vercel.app
# (adds a one-tap "Run the Gate" link to Telegram alerts).
PUBLIC_APP_URL=
# Override the Axiom deep-link base if the format differs (default below).
AXIOM_BASE_URL=https://axiom.trade/meme
